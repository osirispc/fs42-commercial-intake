#!/usr/bin/env bash
set -euo pipefail

SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}")"
PROJECT_DIR="$(cd "$(dirname "$SCRIPT_PATH")/.." && pwd)"
CONFIG_FILE="$PROJECT_DIR/config/intake.env"

if [ ! -f "$CONFIG_FILE" ]; then
  echo "Missing config file:"
  echo "$CONFIG_FILE"
  exit 1
fi

source "$CONFIG_FILE"

URL="${1:-}"

if [ -z "$URL" ]; then
  echo "Usage:"
  echo "  commercial-one 'YOUTUBE_VIDEO_URL'"
  exit 1
fi

mkdir -p "$RAW_DIR" "$READY_DIR"

echo "[COMMERCIAL INTAKE] Project: $PROJECT_DIR"
echo "[COMMERCIAL INTAKE] Downloading one video..."

"${YTDLP_BIN:-yt-dlp}" \
  --no-playlist \
  -f "bv*[height<=${MAX_HEIGHT}]+ba/b[height<=${MAX_HEIGHT}]" \
  --merge-output-format mp4 \
  -o "$RAW_DIR/%(title).80s.%(ext)s" \
  "$URL"

latest="$(find "$RAW_DIR" -maxdepth 1 -type f -printf '%T@ %p\n' | sort -nr | head -n 1 | cut -d' ' -f2-)"

if [ -z "$latest" ]; then
  echo "No downloaded file found."
  exit 1
fi

base="$(basename "$latest")"
name="${base%.*}"

echo "[COMMERCIAL INTAKE] Converting for FieldStation42..."

ffmpeg -y -i "$latest" \
  -vf "scale='min(1280,iw)':-2,fps=30" \
  -c:v libx264 -preset veryfast -crf "$VIDEO_CRF" \
  -c:a aac -b:a "$AUDIO_BITRATE" \
  -movflags +faststart \
  "$READY_DIR/${name}.mp4"

echo
echo "Commercial ready:"
echo "$READY_DIR/${name}.mp4"

if [ -n "${FS42_COMMERCIAL_DIR:-}" ] && [ -d "$FS42_COMMERCIAL_DIR" ]; then
  echo
  echo "[COMMERCIAL INTAKE] Copying to FieldStation42..."
  cp "$READY_DIR/${name}.mp4" "$FS42_COMMERCIAL_DIR/"
  echo "Copied to: $FS42_COMMERCIAL_DIR"
fi
