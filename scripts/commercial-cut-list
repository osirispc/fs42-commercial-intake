#!/usr/bin/env bash
set -euo pipefail

INPUT_FILE="${1:-}"
CUT_FILE="${2:-}"

if [ -z "$INPUT_FILE" ] || [ -z "$CUT_FILE" ]; then
  echo "Usage:"
  echo "  commercial-cut-list INPUT_VIDEO CUT_SHEET"
  echo
  echo "Example:"
  echo "  commercial-cut-list \"\$HOME/Videos/fieldstation42-commercials/ready/block.mp4\" \"\$HOME/projects/fs42-commercial-intake/cuts/halloween-1985-vol507.txt\""
  exit 1
fi

if [ ! -f "$INPUT_FILE" ]; then
  echo "Input video not found:"
  echo "$INPUT_FILE"
  exit 1
fi

if [ ! -f "$CUT_FILE" ]; then
  echo "Cut sheet not found:"
  echo "$CUT_FILE"
  exit 1
fi

OUT_DIR="$HOME/Videos/fieldstation42-commercials/cut"
mkdir -p "$OUT_DIR"

echo
echo "=============================================="
echo " COMMERCIAL CUT LIST"
echo "=============================================="
echo
echo "Input video:"
echo "$INPUT_FILE"
echo
echo "Cut sheet:"
echo "$CUT_FILE"
echo
echo "Output folder:"
echo "$OUT_DIR"
echo

COUNT=0

while read -r START END NAME REST; do
  [[ -z "${START:-}" ]] && continue
  [[ "$START" =~ ^# ]] && continue

  if [ -z "${END:-}" ] || [ -z "${NAME:-}" ]; then
    echo "Skipping bad line:"
    echo "  $START $END $NAME"
    continue
  fi

  COUNT=$((COUNT + 1))

  SAFE_NAME="$(echo "$NAME" \
    | tr ' ' '-' \
    | tr '[:upper:]' '[:lower:]' \
    | tr -cd '[:alnum:]_-')"

  if [ -z "$SAFE_NAME" ]; then
    SAFE_NAME="commercial-clip-$(printf '%03d' "$COUNT")"
  fi

  OUT_FILE="$OUT_DIR/${SAFE_NAME}.mp4"

  echo
  echo "----------------------------------------------"
  echo "Cut #$COUNT"
  echo "Name:  $SAFE_NAME"
  echo "Start: $START"
  echo "End:   $END"
  echo "Out:   $OUT_FILE"
  echo "----------------------------------------------"

  ffmpeg -y \
    -ss "$START" \
    -to "$END" \
    -i "$INPUT_FILE" \
    -c:v libx264 -preset veryfast -crf 23 \
    -c:a aac -b:a 128k \
    -movflags +faststart \
    "$OUT_FILE"

done < "$CUT_FILE"

echo
echo "=============================================="
echo " DONE"
echo "=============================================="
echo
echo "Created clips:"
find "$OUT_DIR" -maxdepth 1 -type f -iname "*.mp4" -printf '%TY-%Tm-%Td %TH:%TM  %s  %p\n' | sort | tail -50
