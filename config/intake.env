# FieldStation42 Commercial Intake Config

RAW_DIR="$HOME/Videos/fieldstation42-commercials/raw"
READY_DIR="$HOME/Videos/fieldstation42-commercials/ready"

MAX_HEIGHT="720"
VIDEO_CRF="23"
AUDIO_BITRATE="128k"

# Set this later once we confirm your real FS42 commercial folder.
FS42_COMMERCIAL_DIR=""

# Use this project's yt-dlp, not FieldStation42's venv yt-dlp
YTDLP_BIN="$HOME/projects/fs42-commercial-intake/.venv/bin/yt-dlp"
